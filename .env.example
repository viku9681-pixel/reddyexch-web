# ============================================================
# ReddyExch — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://djirwwtijunzrpanfxwa.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>   # SERVER ONLY — never expose to client

# --- Vercel KV (Redis) ---
KV_URL=<your-vercel-kv-url>
KV_REST_API_URL=<your-vercel-kv-rest-api-url>
KV_REST_API_TOKEN=<your-vercel-kv-rest-api-token>
KV_REST_API_READ_ONLY_TOKEN=<your-vercel-kv-read-only-token>

# --- Google Analytics 4 ---
NEXT_PUBLIC_GA4_MEASUREMENT_ID=<G-XXXXXXXXXX>
GA4_API_SECRET=<your-ga4-api-secret>

# --- Google Search Console ---
GSC_SITE_URL=https://reddyexchgaming.com

# --- WhatsApp Business ---
WHATSAPP_BUSINESS_NUMBER=<+91XXXXXXXXXX>   # E.164 format
WHATSAPP_FALLBACK_PHONE=<+91XXXXXXXXXX>
WHATSAPP_FALLBACK_EMAIL=<support@reddyexchgaming.com>

# --- Compliance ---
AGE_GATE_EXIT_URL=https://www.google.com

# --- Rank Tracking (optional) ---
AHREFS_API_KEY=<your-ahrefs-api-key>
SEMRUSH_API_KEY=<your-semrush-api-key>

# --- App ---
NEXT_PUBLIC_SITE_URL=https://reddyexchgaming.com
NODE_ENV=development
